import rclpy
from rclpy.node import Node
import sys
from agibot_d1_interface.srv import AddInts
class MinClient(Node):
    def __init__(self):
        super().__init__('minclient_py')
        self.cli=self.create_client(AddInts,'add_ints')
        while not self.cli.wait_for_service(timeout_sec=1.0):
            self.get_logger().info('服务连接中，请稍候')
        self.req=AddInts.Request()
    def send_request(self):
        self.req.num1 = int(sys.argv[1])
        self.req.num2 = int(sys.argv[2])
        self.future = self.cli.call_async(self.req)
def main():
    rclpy.init()
    minclient=MinClient()
    minclient.send_request()
    rclpy.spin_until_future_complete(minclient,minclient.future)    
    try:
        response=minclient.future.result()
    except Exception as e:
        minclient.get_logger().info('服务请求失败:%r'%(e,))
    else:
        minclient.get_logger().info(f'{minclient.req.num1}+{minclient.req.num2}={response.sum}')
    rclpy.shutdown()   
if __name__=='__main__':
    main()

        
