import rclpy
from rclpy.node import Node
from agibot_d1_interface.srv import AddInts
class MinService(Node):
    def __init__(self):
        super().__init__('min_service_py')
        self.srv=self.create_service(AddInts,'add_ints',self.add_two_ints_callback)
        self.get_logger().info('服务器启动')
    def add_two_ints_callback(self,request,response):
        response.sum=request.num1+request.num2
        self.get_logger().info(f'{request.num1}+{request.num2}={response.sum}')
        return response
def main():
    rclpy.init()
    min_service=MinService()
    rclpy.spin(min_service)
if __name__=='__main__':
    main()
