import rclpy
from rclpy.node import Node
from std_msgs.msg import String


class MinSubscribe(Node):
    def __init__(self):
        super().__init__('subscriber_py')  # 修复: 原为 'subscribe_py'，拼写错误
        self.subscription = self.create_subscription(
            String, 'topic', self.listener_callback, 10)

    def listener_callback(self, msg):
        self.get_logger().info(f'订阅的消息：{msg.data}')  # 修复: 原缺少 f 前缀，{msg.data} 不会被替换


def main(args=None):
    rclpy.init(args=args)
    min_subscriber = MinSubscribe()
    rclpy.spin(min_subscriber)
    rclpy.shutdown()  # 修复: 原缺少 shutdown() 调用


if __name__ == '__main__':
    main()
